# Server Configuration
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Database Configuration (Development - Local PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ecommercedb
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# Database Configuration (Production - Render PostgreSQL)
# Render provides these variables automatically when you create a PostgreSQL database
# DATABASE_HOST=<internal-database-url>.render.com
# DATABASE_PORT=5432
# DATABASE_NAME=<database-name>
# DATABASE_USER=<database-user>
# DATABASE_PASSWORD=<auto-generated-password>
# 
# Note: Render also provides DATABASE_URL, but we use individual variables
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin User Seeder
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=12345678

# CORS Configuration (comma-separated origins for production)
CORS_ORIGINS=http://localhost:4200,https://your-frontend-name.onrender.com

# Entity Path (for TypeORM)
DATABASE_ENTITIES=dist/**/*.entity.{ts,js}

