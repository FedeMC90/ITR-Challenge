# Docker Compose Environment Variables
# Copy this file to .env.docker and customize for your environment

# Backend Configuration
PORT=3000
BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# Database Configuration
DATABASE_HOST=postgres
DATABASE_NAME=ecommercedb
DATABASE_USER=hassan
DATABASE_PASSWORD=password
DATABASE_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Security
JWT_SECRET=change-this-in-production-to-a-secure-random-string

# Admin User (created on first run)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=12345678

# Frontend Configuration
FRONTEND_PORT=80
VITE_API_URL=http://localhost:3000/api
